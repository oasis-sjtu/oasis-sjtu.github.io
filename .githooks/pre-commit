#!/bin/sh
set -eu

changed="$(git diff --cached --name-only -- static/publications.csv static/papers || true)"
if [ -z "$changed" ]; then
  exit 0
fi

if [ -x ./venv/bin/python ]; then
  PYTHON=./venv/bin/python
else
  PYTHON=python3
fi

echo "Running publication PDF gate..."
"$PYTHON" -B scripts/manage_publication_pdfs.py --pre-commit
